@page
@model IndexModel
@inject Microsoft.AspNetCore.Mvc.Localization.IHtmlLocalizer<NailArtHub.SharedResource> Localizer
@{
    ViewData["Title"] = "Home page";
}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<head>
<style>

    .nailsy-hero {
        background-color: #FAF6F0;
        min-height: 85vh;
        display: flex;
        align-items: center;
        padding: 0 60px 60px 60px;
        font-family: 'Montserrat', sans-serif;
    }

    .hero-text-side {
        flex: 1.4;
        padding-right: 40px;
    }

    .hero-tagline {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 4px;
        color: #C49A45;
        margin-bottom: 20px;
        font-weight: 600;
    }

    .hero-title {
        font-family: 'Playfair Display', serif;
        font-size: 4.5rem;
        color: #1A1A1A;
        line-height: 1.1;
        margin-bottom: 25px;
        font-weight: 400;
        letter-spacing: -1px;
    }

    .hero-title em {
        font-style: italic;
        font-family: 'Playfair Display', serif;
    }

    .hero-description {
        font-size: 1.05rem;
        color: #555555;
        line-height: 1.8;
        margin-bottom: 40px;
        letter-spacing: 0.5px;
        max-width: 90%;
    }

     .btn-satrt {
        display: inline-block;
        border: 1px solid #1A1A1A;
        color: #1A1A1A;
        padding: 15px 45px;
        text-transform: uppercase;
        font-size: 0.9rem;
        letter-spacing: 2px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.4s ease;
    }

     .btn-satrt:hover {
        background-color: #1A1A1A;
        color: #FAF6F0;
     }

    /* Right side pic */
    .hero-image-side {
        flex: 1;
        height: 100vh;
        overflow: hidden;
    }

    .hero-image-side img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .hero-hand-fade {
    width: 100% !important;
    height: auto !important;
    object-fit: cover !important;
    object-position: top !important;
    margin-bottom: -200px !important; 
    position: relative !important;
    z-index: 0 !important;
    -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 75%, rgba(0,0,0,0) 100%) !important;
    mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 75%, rgba(0,0,0,0) 100%) !important;
    }

    .reveal-on-scroll {
        opacity: 0;
        transform: translateY(30px);
        will-change: transform, opacity;
        backface-visibility: hidden;
        transition: opacity 1s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    /* detect scrolling to trigger this class */
    .reveal-on-scroll.active {
        opacity: 1;
        transform: translateY(0);
    }

    .feature-card {
        flex: 1;
        background: #FFFDFB;
        padding: 50px 30px;
        border: 1px solid #EAE5DC;
        text-align: center;
        box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    }
            .lang-zh, .lang-en {
                display: none;
            }

            :lang(zh) .lang-zh {
                display: inline;
            }

            :lang(en) .lang-en {
                display: inline;
            }
</style>
</head>
<body>
<div style="background-color: #FAF6F0; width: 100%; min-height: 100vh; overflow: hidden; margin: 0; padding: 0;">
        <div class="nailsy-hero" style="background-color: transparent; min-height: 85vh; display: flex; align-items: center; padding: 0 60px 60px 60px;">
    <!-- Left side text -->
            <div class="hero-text-side" style="flex: 1; padding-right: 80px;">
        <div class="hero-tagline">Trendy & Smart Exploration</div>
                <h1 class="hero-title">
                    <!-- EN  -->
                    <span class="lang-en">
                        Find the Best<br>
                        <em>Nail Trends</em> Near You.
                    </span>

                    <!-- ZH -->
                    <span class="lang-zh">
                        探索在您身邊的<br>
                        最新<em>美甲潮流</em>
                    </span>
                </h1>
        <div class="hero-description">
            Looking for the latest trending colors? The most popular styles? Or trying to find a nail salon near you?<br>
            Our platform offers the most intuitive search experience.<br>
            Whether you're gathering inspiration or seeking professional services,<br>
            your beauty desires can be effortlessly fulfilled right here!
        </div>
    </div>

    <!-- Right side poster -->
            <div class="hero-image-side" style="flex: 1; height: 70vh; position: relative; overflow: visible !important;">
                <img src="~/images/nail-hero.png" class="hero-hand-fade" alt="Minimalist Nail Art">
            </div>
</div>
<!-- ================= Section 2: About ================= -->
        <div class="reveal-on-scroll" style="background-color: transparent; padding: 100px 60px;">
    <div style="max-width: 900px; margin: 0 auto; text-align: center;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 2.8rem; color: #1A1A1A; margin-bottom: 40px; letter-spacing: 1px;">
                    @Localizer["AboutLabel"]
        </h2>
        <p style="font-family: 'Montserrat', sans-serif; font-size: 1.15rem; color: #555555; line-height: 2; letter-spacing: 0.5px;">
                    We provide a seamless and highly intuitive navigation experience.<br>
                    Whether you are searching for your next nail art inspiration<br>
                    or looking for a certified professional,<br>
                    our platform leverages advanced data analytics to integrate the hottest trends from YouTube, Pinterest, and Instagram with premier salons across Taiwan.<br>
                    We aim to create an intelligent nail navigation hub<br>
                    where achieving your beauty aesthetic is smooth and simple.
        </p>
    </div>
</div>

<!-- ================= Section 3: How to use ================= -->
        <div class="reveal-on-scroll" style="background-color: transparent; padding: 100px 60px;">
    <div style="max-width: 1200px; margin: 0 auto;">

        <!-- Section -->
        <div style="text-align: center; margin-bottom: 80px;">
            <h2 style="font-family: 'Playfair Display', serif; font-size: 2.8rem; color: #1A1A1A; letter-spacing: 1px;">
                        @Localizer["HowItWorksLabel"]How It Works
            </h2>
            <p style="font-size: 0.9rem; text-transform: uppercase; letter-spacing: 3px; color: #C49A45; margin-top: 10px; font-weight: 600;">
                Master the Fingertip Trends in 3 Simple Steps
            </p>
        </div>

        <div style="display: flex; gap: 40px; justify-content: space-between;">
                    <div class="feature-card">
                        <div style="font-family: 'Playfair Display', serif; font-size: 2rem; color: #C49A45; margin-bottom: 20px;">01</div>
                        <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 15px; color: #1A1A1A;">Big Data Trend Scraping</h3>
                        <p style="color: #666; font-size: 0.95rem; line-height: 1.6;">Automatically tracks the latest nail art videos and images across YouTube, Pinterest, and Instagram, precisely analyzing views and trending keyword tags.</p>
                    </div>
                    <div class="feature-card">
                        <div style="font-family: 'Playfair Display', serif; font-size: 2rem; color: #C49A45; margin-bottom: 20px;">02</div>
                        <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 15px; color: #1A1A1A;">Intuitive Tag Filtering</h3>
                        <p style="color: #666; font-size: 0.95rem; line-height: 1.6;">Effortlessly filter styles that match your current mood with a single click, based on trending tags like Cateye, French, or Japanese style.</p>
                    </div>
                    <div class="feature-card">
                        <div style="font-family: 'Playfair Display', serif; font-size: 2rem; color: #C49A45; margin-bottom: 20px;">03</div>
                        <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 15px; color: #1A1A1A;">Curated Salon Matchmaking</h3>
                        <p style="color: #666; font-size: 0.95rem; line-height: 1.6;">Directly connects you to local nail artists' portfolios on Instagram and Pinterest, bringing the best local salons right to your screen.</p>
                    </div>
                </div>
        </div><br>
            <!-- Button to Services -->
            <div style="display: flex; justify-content: center; margin-top: 60px;">
                <a asp-page="/Services" class="btn-satrt">@Localizer["ExploreNowLabel"]</a>
            </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
                    // Built an observer
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                        observer.unobserve(entry.target);
                    }
                });
            }, {
                threshold: 0.15
            });

            const items = document.querySelectorAll('.reveal-on-scroll');
            items.forEach(item => observer.observe(item));
        });
    </script>
}
</body>