@page
@model NailArtHub.Pages.PartnerFormModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject Microsoft.AspNetCore.Mvc.Localization.IHtmlLocalizer<NailArtHub.SharedResource> Localizer
@{
    ViewData["Title"] = "Become a Partner - NailArtHub";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<head>
<style>
    .services-style-page {
        background-color: #FAF6F0;
        min-height: 100vh;
        font-family: 'Montserrat', sans-serif;
        padding: 60px;
        color: #1A1A1A;
    }

    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 3rem;
        text-align: center;
        margin-bottom: 50px;
        letter-spacing: 1px;
    }

    :lang(zh) .page-title {
        font-family: "PMingLiU-ExtB", "MingLiU", "Microsoft JhengHei", "Songti TC", "Noto Serif TC", serif !important;
        font-weight: 700 !important;
        font-size: 3.2rem !important;
        letter-spacing: 2px !important;
        color: #1A1A1A !important;
    }

    .form-container,
    .form-container label,
    .form-container input,
    .form-container select,
    .form-container option,
    .form-container span {
        font-family: 'Montserrat', 'Noto Sans TC', sans-serif !important;
        font-weight: 300 !important;
        letter-spacing: 1px !important;
    }

        .form-container label {
            font-weight: 400 !important;
            margin-bottom: 8px;
            color: #333333 !important;
        }

    .form-container {
        background: #FFFDFB;
        border: 1px solid #EAE5DC;
        padding: 40px;
        max-width: 650px;
        margin: 0 auto;
    }

    .custom-input {
        width: 100%;
        background-color: #FFFDFB;
        border: 1px solid #EAE5DC;
        padding: 12px 20px;
        font-size: 0.95rem;
        letter-spacing: 0.5px;
        outline: none;
        transition: border-color 0.3s;
        border-radius: 0;
        color: #1A1A1A;
    }

        .custom-input:focus {
            border-color: #1A1A1A;
        }

    .btn-submit {
        background-color: #1A1A1A;
        color: #FAF6F0;
        border: none;
        padding: 15px 35px;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-weight: 500;
        transition: background-color 0.3s;
        width: 100%;
        cursor: pointer;
    }

        .btn-submit:hover {
            background-color: #404040;
        }

    .form-tag-pill {
        background-color: #FFFDFB;
        border: 1px solid #EAE5DC;
        padding: 8px 16px;
        border-radius: 30px;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-block;
        user-select: none;
    }

    .style-checkbox:checked + .form-tag-pill {
        background-color: #1A1A1A !important;
        color: #FAF6F0 !important;
        border-color: #1A1A1A !important;
    }

    .form-tag-pill:hover {
        border-color: #1A1A1A;
    }
            /* --- 📱phone version --- */
            @@media screen and (max-width: 768px) {
                .services-style-page {
                    padding: 30px 16px 60px 16px !important;
                    min-height: auto !important;
                }

                :lang(zh) .page-title,
                .page-title {
                    font-size: 2.0rem !important;
                    line-height: 1.4 !important;
                    margin-bottom: 30px !important;
                    text-align: center !important;
                }

                .results-layout {
                    display: flex !important;
                    flex-direction: column !important;
                    width: 100% !important;
                    gap: 20px !important;
                }

                input[type="text"], select, .form-control, .custom-input {
                    width: 100% !important;
                    height: auto !important;
                    font-size: 0.9rem !important;
                    border: 1px solid #EAE5DC !important;
                    border-radius: 4px !important;
                    padding: 12px 12px !important;
                    box-sizing: border-box !important;
                }

                .form-container {
                    display: block !important;
                    width: 100% !important;
                    padding: 24px 20px !important;
                    box-sizing: border-box !important;
                }

                .custom-input {
                    padding: 12px 15px !important;
                    font-size: 0.85rem !important;
                }

                .btn-submit {
                    padding: 14px !important;
                    font-size: 0.9rem !important;
                    width: 100% !important;
                }
                }
</style>
</head>
<body>
<div class="services-style-page">
    <div class="container" style="padding: 0;">
        @if (Model.IsSuccess)
        {
            <div class="form-container text-center animate__animated animate__fadeIn" style="padding: 60px 40px;">
                <div class="mb-4" style="font-size: 3rem;"></div>
                <h3 style="font-family: 'Playfair Display', serif; font-size: 2rem; margin-bottom: 20px;">Thank You</h3>
                <p style="color: #666; font-size: 0.95rem; line-height: 1.8; margin-bottom: 30px;">
                    @Localizer["SubmittedSuccessfulLabel"]<br />
                    @Localizer["SubmittedSLabel2"]
                </p>
                <a asp-page="/Services" class="btn-submit" style="text-decoration: none; display: inline-block; width: auto; padding: 12px 40px;">
                    @Localizer["ExploreLabel"]
                </a>
            </div>
        }
        else
        {
            <h1 class="page-title">@Localizer["PartnerLabel"]</h1>

            <form method="post" class="form-container animate__animated animate__fadeIn">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <div class="mb-4">
                        <label class="form-label style-label" style="font-size: 1.05rem; letter-spacing: 1px; font-weight: 700; color: #1A1A1A; margin-bottom: 12px;">
                            @Localizer["SupportPlanTitle"]
                        </label>

                        <div class="support-info-box" style="line-height: 1.7; color: #333; font-size: 0.9rem; padding: 25px; border: 1.5px solid #1A1A1A; background-color: #FFFDFB;">
                            <p class="mb-3" style="font-weight: 300;">
                                @{
                                    var descText = Localizer["SupportPlanDesc"].Value;
                                    var highlightedText = descText.Replace("NT$300", "<strong style='font-weight: 700; color: #1A1A1A; text-decoration: underline;'>NT$300</strong>");
                                }
                                @Html.Raw(highlightedText)
                            </p>
                            <a href="/Support" style="color: #1A1A1A; text-decoration: underline; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; font-size: 0.75rem;">
                                → @Localizer["LearnMoreLabel"]
                            </a>
                        </div>
                    </div>

                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-4">
                    <label asp-for="ApplyForm.ShopName" class="form-label style-label" style="font-size: 0.8rem; letter-spacing: 1px; font-weight: 600; color: #555;">@Localizer["ShopNameLabel"]</label>
                    <input asp-for="ApplyForm.ShopName" class="custom-input" placeholder="Ex: Beauty Nails Salon" />
                    <span asp-validation-for="ApplyForm.ShopName" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ApplyForm.OwnerName" class="form-label style-label" style="font-size: 0.8rem; letter-spacing: 1px; font-weight: 600; color: #555;">@Localizer["OwnerNameLabel"]</label>
                    <input asp-for="ApplyForm.OwnerName" class="custom-input" placeholder="Ex: Vivian Chen" />
                    <span asp-validation-for="ApplyForm.OwnerName" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    @await Html.PartialAsync("_LocationSelector")
                        <input type="hidden" id="hiddenCity" name="SelectedCity" value="@Model.SelectedCity" />
                        <input type="hidden" id="hiddenDistrict" name="SelectedDistrict" value="@Model.SelectedDistrict" />
                </div>

                <div class="mb-4">
                    <label asp-for="ApplyForm.Address" class="form-label style-label" style="font-size: 0.8rem; letter-spacing: 1px; font-weight: 600; color: #555;">@Localizer["ShopNameAddress"]</label>
                    <input asp-for="ApplyForm.Address" class="custom-input" placeholder="Ex: 大安區敦化南路一段XXX號" />
                    <span asp-validation-for="ApplyForm.Address" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ApplyForm.InstagramUrl" class="form-label style-label" style="font-size: 0.8rem; letter-spacing: 1px; font-weight: 600; color: #555;">@Localizer["InstaLabel"]</label>
                    <input asp-for="ApplyForm.InstagramUrl" class="custom-input" placeholder="https://www.instagram.com/your_salon" />
                    <span asp-validation-for="ApplyForm.InstagramUrl" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ApplyForm.PinterestUrl" class="form-label style-label" style="font-size: 0.8rem; letter-spacing: 1px; font-weight: 600; color: #555;">@Localizer["InstaPostLabel"]</label>
                        <input asp-for="ApplyForm.PinterestUrl" class="custom-input" placeholder="@Localizer["IGpost"]" />
                    <span asp-validation-for="ApplyForm.PinterestUrl" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                        <label asp-for="ApplyForm.PaymentProofCode" class="form-label style-label" style="font-size: 0.8rem; letter-spacing: 1px; font-weight: 600; color: #555;">@Localizer["ECpay"]</label>
                        <a href="https://p.ecpay.com.tw/37276AC" target="_blank" style="font-size: 0.75rem; color: #0d6efd; text-decoration: none; font-weight: 500; letter-spacing: 0.5px;">
                            🔗 @Localizer["PaymentLink"]
                        </a>
                        <input asp-for="ApplyForm.PaymentProofCode" class="custom-input" placeholder="ex：260610xxxxxxx" />
                    <span asp-validation-for="ApplyForm.PaymentProofCode" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label style-label d-block mb-3" style="font-size: 0.8rem; letter-spacing: 1px; font-weight: 600; color: #555;">@Localizer["ServicesTagLabel"]</label>

                    <div class="d-flex flex-wrap gap-2" style="background-color: #FFFDFB; padding: 20px; border: 1px solid #EAE5DC;">
                        @if (Model.AvailableTags != null)
                        {
                            foreach (var tag in Model.AvailableTags)
                            {
                                <div style="position: relative;">
                                    <input class="style-checkbox" type="checkbox" name="SelectedTagIds" value="@tag.Id" id="tag_@tag.Id" style="display: none;" />
                                    <label class="form-tag-pill" for="tag_@tag.Id">
                                        # @tag.TagName
                                    </label>
                                </div>
                            }
                        }
                    </div>
                </div>

                <div class="mb-5 form-check d-flex align-items-start mt-4" style="padding-left: 0;">
                    <input type="checkbox" id="agreeCheck" required style="cursor: pointer; width: 16px; height: 16px; margin-top: 3px; border: 1px solid #EAE5DC;" />
                    <label for="agreeCheck" style="color: #666; font-size: 0.75rem; line-height: 1.6; cursor: pointer; user-select: none; margin-left: 10px;">
                        @Localizer["TermAgreementText"]
                    </label>
                </div>

                <button type="submit" class="btn-submit">
                    @Localizer["SubmitApplicationLabel"]
                </button>
            </form>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    document.addEventListener("DOMContentLoaded", function() {
        const maxTags = 5;
        const checkboxes = document.querySelectorAll('.style-checkbox');

        checkboxes.forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                const checkedCount = document.querySelectorAll('.style-checkbox:checked').length;

                if (checkedCount >= maxTags) {
                    checkboxes.forEach(cb => {
                        if (!cb.checked) {
                            cb.disabled = true;
                            const label = document.querySelector(`label[for="${cb.id}"]`);
                            if (label) {
                                label.style.opacity = '0.5';
                                label.style.cursor = 'not-allowed';
                            }
                        }
                    });
                } else {
                    checkboxes.forEach(cb => {
                        cb.disabled = false;
                        const label = document.querySelector(`label[for="${cb.id}"]`);
                        if (label) {
                            label.style.opacity = '1';
                            label.style.cursor = 'pointer';
                        }
                    });
                }
            });
        });

        function bindLocationSync() {
            const citySelect = document.querySelector('.js-real-city-select') || document.getElementById('globalCitySelect');
            const distSelect = document.querySelector('.js-real-dist-select') || document.getElementById('globalDistrictSelect');
            
            const hiddenCity = document.getElementById('hiddenCity');
            const hiddenDistrict = document.getElementById('hiddenDistrict');

            if (!citySelect || !distSelect) {
                console.error("❌ 找不到下拉選單元素，請檢查 _LocationSelector.cshtml 的 ID 或 Class 是否正確。");
                return;
            }

            console.log("✅ 成功對齊選單元素，進入穩健防禦模式...");

            function getChineseCity() {
                const opt = citySelect.options[citySelect.selectedIndex];
                if (!opt || !opt.value) return "";
                return opt.getAttribute("data-zh") || opt.text;
            }

            function getChineseDistrict() {
                const opt = distSelect.options[distSelect.selectedIndex];
                if (!opt || !opt.value) return "";
                return opt.text; 
            }

            citySelect.addEventListener('change', function (e) {
                e.stopPropagation(); 
                
                setTimeout(() => {
                    const c = getChineseCity();
                    const d = getChineseDistrict();
                    if (hiddenCity) hiddenCity.value = c;
                    if (hiddenDistrict) hiddenDistrict.value = d;
                    console.log("👉【縣市變更】已同步中文，等待使用者選擇行政區...", c, d);
                }, 100);
            });

            distSelect.addEventListener('change', function (e) {
                e.stopPropagation();
                
                const d = getChineseDistrict();
                if (hiddenDistrict) hiddenDistrict.value = d;
                console.log("👉【行政區變更】已同步中文:", d);
            });

            setTimeout(() => {
                const c = getChineseCity();
                const d = getChineseDistrict();
                if (hiddenCity) hiddenCity.value = c;
                if (hiddenDistrict) hiddenDistrict.value = d;
            }, 300);

            const form = citySelect.closest('form');
            if (form) {
                form.addEventListener('submit', function (e) {
                    const finalCity = getChineseCity();
                    const finalDist = getChineseDistrict();

                    console.log("偵測到表單送出動作，進行最終檢查...", finalCity, finalDist);

                    if (!finalCity || !finalDist || 
                        finalCity.includes("所有") || finalDist.includes("所有") || 
                        finalCity.includes("選擇") || finalDist.includes("選擇") ||
                        finalCity.includes("All") || finalDist.includes("All")) {
                        
                        e.preventDefault();
                        e.stopPropagation();
                        alert("請務必選擇正確的縣市與行政區！");
                        return false;
                    }

                    if (hiddenCity) hiddenCity.value = finalCity;
                    if (hiddenDistrict) hiddenDistrict.value = finalDist;

                    const currentCityOpt = citySelect.options[citySelect.selectedIndex];
                    if (currentCityOpt) {
                        currentCityOpt.value = finalCity; 
                    }
                    const currentDistOpt = distSelect.options[distSelect.selectedIndex];
                    if (currentDistOpt) {
                        currentDistOpt.value = finalDist;
                    }

                    console.log("🚀【安全放行】實體與隱藏欄位皆已鎖死，準備送往後端產生綠界付款碼！");
                });
            }
        }

        setTimeout(bindLocationSync, 800);
    });
    </script>
}
</body>