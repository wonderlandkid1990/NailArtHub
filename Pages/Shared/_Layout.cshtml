@using Microsoft.AspNetCore.Builder
@using Microsoft.AspNetCore.Localization
@using Microsoft.Extensions.Options
@inject Microsoft.AspNetCore.Mvc.Localization.IHtmlLocalizer<NailArtHub.SharedResource> Localizer
@inject IOptions<RequestLocalizationOptions> LocOptions
@{
    var cookieName = CookieRequestCultureProvider.DefaultCookieName;
    var cultureCookie = Context.Request.Cookies[cookieName];
    string currentCulture = "zh";

    if (!string.IsNullOrEmpty(cultureCookie))
    {
        var parts = cultureCookie.Split('|');
        var uicPart = parts.FirstOrDefault(p => p.StartsWith("uic="));
        if (uicPart != null)
        {
            currentCulture = uicPart.Substring(4);
        }
    }
    if (!string.IsNullOrEmpty(Context.Request.Query["culture"]))
    {
        currentCulture = Context.Request.Query["culture"].ToString();
    }
    var returnUrl = string.IsNullOrEmpty(Context.Request.Path) ? "~/" : $"~{Context.Request.Path}{Context.Request.QueryString}";
}

<!DOCTYPE html>
<html lang="@(currentCulture.StartsWith("zh") ? "zh-Hant" : "en")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NailArtHub</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/NailArtHub.styles.css" asp-append-version="true" />
</head>
<body>
    <header style="background-color: #FAF6F0 !important;">
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm p-0" style="background: transparent !important; border: none !important;">
            <div class="container-fluid p-0 d-flex align-items-center justify-content-between">
                <!-- Logo -->
                <div class="logo-container px-4 py-2 d-flex align-items-center">
                    <a class="navbar-brand m-0 p-0 d-flex align-items-center" href="/">
                        <img src="~/images/NAH.png" alt="NAH Logo" style="height: 140px; width: auto; mix-blend-mode: multiply !important;">
                        <span style="font-size: 10px; font-weight: 500; color: #1a1a1a; letter-spacing: 3px; line-height: 1; margin-top: 2px; font-family: sans-serif;">
                            NAIL ART HUB
                        </span>
                    </a>
                </div>

                <button class="navbar-toggler me-3" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- ZH/CN btn -->
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end pe-4">
                    <ul class="navbar-nav gap-4 d-flex align-items-center">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold" style="font-size: 15px; letter-spacing: 1px;" asp-area="" asp-page="/Index">@Localizer["HomeLabel"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold" style="font-size: 15px; letter-spacing: 1px;" asp-area="" asp-page="/Services">@Localizer["ServicesLabel"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold" style="font-size: 15px; letter-spacing: 1px;" asp-area="" asp-page="/PartnerList">@Localizer["Partner_List"]</a>
                        </li>

                        <li class="nav-item ms-2">
                            <form id="selectLanguageForm" asp-page="/SetLanguage" method="post" asp-route-returnUrl="@returnUrl" class="m-0">
                                <input type="hidden" name="culture" id="layoutCultureInput" value="" />

                                <div style="font-size: 0.85rem; letter-spacing: 1px; font-family: 'Montserrat', sans-serif;">
                                    <a href="?culture=zh"
                                       style="text-decoration: none; padding: 0 4px; transition: color 0.3s;
                                        color: @(currentCulture == "zh" ? "#1A1A1A" : "#ccc"); font-weight: @(currentCulture == "zh" ? "700" : "400");">
                                        ZH
                                    </a>

                                    <span style="color: #EAE5DC; padding: 0 1px;">|</span>

                                    <a href="?culture=en"
                                       style="text-decoration: none; padding: 0 4px; transition: color 0.3s;
                                        color: @(currentCulture == "en" ? "#1A1A1A" : "#ccc"); font-weight: @(currentCulture == "en" ? "700" : "400");">
                                        EN
                                    </a>
                                </div>
                            </form>
                        </li>
                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - NailArtHub - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        function changeGlobalLanguage(cultureCode) {
        const input = document.getElementById('layoutCultureInput');
        const form = document.getElementById('selectLanguageForm');
        if (input && form) {
        input.value = cultureCode;
        form.submit();
        }
        }

        function submitLocationForm() {
        const form = document.getElementById("locationForm");
        if (form) {
        form.submit();
        }
        }
    </script>
</body>
</html>