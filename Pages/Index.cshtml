@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<head>
<style>

    .nailsy-hero {
        background-color: #FAF6F0;
        min-height: 85vh;
        display: flex;
        align-items: center;
        padding: 0 60px 60px 60px;
        font-family: 'Montserrat', sans-serif;
    }

    .hero-text-side {
        flex: 1;
        padding-right: 80px;
    }

    .hero-tagline {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 4px;
        color: #C49A45;
        margin-bottom: 20px;
        font-weight: 600;
    }

    .hero-title {
        font-family: 'Playfair Display', serif;
        font-size: 4rem;
        color: #1A1A1A;
        line-height: 1.15;
        margin-bottom: 30px;
        font-weight: 400;
    }

        .hero-title em {
            font-style: italic;
            font-family: 'Playfair Display', serif;
        }

    .hero-description {
        font-size: 1.05rem;
        color: #555555;
        line-height: 1.8;
        margin-bottom: 40px;
        letter-spacing: 0.5px;
    }

    .btn-nailsy {
        display: inline-block;
        border: 1px solid #1A1A1A;
        color: #1A1A1A;
        padding: 15px 45px;
        text-transform: uppercase;
        font-size: 0.9rem;
        letter-spacing: 2px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.4s ease;
    }

        .btn-nailsy:hover {
            background-color: #1A1A1A;
            color: #FAF6F0;
        }

    /* Right side pic */
    .hero-image-side {
        flex: 1;
        height: 70vh;
        overflow: hidden;
    }

        .hero-image-side img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .reveal-on-scroll {
            opacity: 0;
            transform: translateY(30px);
            will-change: transform, opacity;
            backface-visibility: hidden;
            transition: opacity 1s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

        /* detect scrolling to trigger this class */
        .reveal-on-scroll.active {
            opacity: 1;
            transform: translateY(0);
        }

        .feature-card {
            flex: 1;
            background: #FFFDFB;
            padding: 50px 30px;
            border: 1px solid #EAE5DC;
            text-align: center;
            box-shadow: 0 4px 20px rgba(0,0,0,0.02);
        }
</style>
</head>
<body>
<div style="background-color: #FAF6F0; width: 100%; min-height: 100vh; overflow: hidden; margin: 0; padding: 0;">
        <div class="nailsy-hero" style="background-color: transparent; min-height: 85vh; display: flex; align-items: center; padding: 0 60px 60px 60px;">
    <!-- Left side text -->
            <div class="hero-text-side" style="flex: 1; padding-right: 80px;">
        <div class="hero-tagline">Trendy & Smart Exploration</div>
        <h1 class="hero-title">
            Find the Best<br>
            <em>Nail Trends</em> Near You.
        </h1>
        <div class="hero-description">
            最新流行色？最流行款式？家附近美甲怎麼找？<br>
            本網頁提供最直覺的檢索，不管是找靈感還是找服務，這裡可以簡單完成妳的願望！
        </div>
        <!-- Button to Services -->
        <a asp-page="/Services" class="btn-nailsy">開始使用 / Explore</a>
    </div>

    <!-- Right side poster -->
            <div class="hero-image-side" style="flex: 1; height: 70vh; overflow: hidden;">
        <img src="~/images/nail-hero.jpg" alt="Minimalist Nail Art">
    </div>
</div>
<!-- ================= Section 2: About ================= -->
        <div class="reveal-on-scroll" style="background-color: transparent; padding: 100px 60px;">
    <div style="max-width: 900px; margin: 0 auto; text-align: center;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 2.8rem; color: #1A1A1A; margin-bottom: 40px; letter-spacing: 1px;">
            About Our Concept
        </h2>
        <p style="font-family: 'Montserrat', sans-serif; font-size: 1.15rem; color: #555555; line-height: 2; letter-spacing: 0.5px;">
            本網頁提供最直覺的檢索，不管是想尋找美甲靈感，還是想尋求專業服務，<br>
            這裡結合了先進的網路數據採集技術，將當下最火熱的 YouTube 影音趨勢與全台優質沙龍進行整合，<br>
            旨在打造一個讓妳輕鬆、簡單就能完成美麗願望的智能美甲導航平台。
        </p>
    </div>
</div>

<!-- ================= Section 3: How to use ================= -->
        <div class="reveal-on-scroll" style="background-color: transparent; padding: 100px 60px;">
    <div style="max-width: 1200px; margin: 0 auto;">

        <!-- Section -->
        <div style="text-align: center; margin-bottom: 80px;">
            <h2 style="font-family: 'Playfair Display', serif; font-size: 2.8rem; color: #1A1A1A; letter-spacing: 1px;">
                How It Works
            </h2>
            <p style="font-size: 0.9rem; text-transform: uppercase; letter-spacing: 3px; color: #C49A45; margin-top: 10px; font-weight: 600;">
                三個步驟 掌握指尖潮流
            </p>
        </div>

        <div style="display: flex; gap: 40px; justify-content: space-between;">
                    <div class="feature-card">
                        <div style="font-family: 'Playfair Display', serif; font-size: 2rem; color: #C49A45; margin-bottom: 20px;">01</div>
                        <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 15px; color: #1A1A1A;">大數據趨勢爬取</h3>
                        <p style="color: #666; font-size: 0.95rem; line-height: 1.6;">全自動追蹤 YouTube,Pinterest和IG最新美甲影片圖片，精準解析觀看量與爆款關鍵字標籤。</p>
                    </div>
                    <div class="feature-card">
                        <div style="font-family: 'Playfair Display', serif; font-size: 2rem; color: #C49A45; margin-bottom: 20px;">02</div>
                        <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 15px; color: #1A1A1A;">直覺式標籤篩選</h3>
                        <p style="color: #666; font-size: 0.95rem; line-height: 1.6;">依據貓眼、法式、日系等流行關鍵字，一鍵篩選出最符合妳當下靈感的款式。</p>
                    </div>
                    <div class="feature-card">
                        <div style="font-family: 'Playfair Display', serif; font-size: 2rem; color: #C49A45; margin-bottom: 20px;">03</div>
                        <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 15px; color: #1A1A1A;">精選沙龍媒合</h3>
                        <p style="color: #666; font-size: 0.95rem; line-height: 1.6;">連結優質美甲師的 Instagram 與 Pinterest 作品牆，在地沙龍一網打盡。</p>
                    </div>
                </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // 建立觀察器
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    // 如果區塊進入畫面中
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                        // 浮現過後就停止觀察該元件，讓動畫只執行一次，保持網頁流暢
                        observer.unobserve(entry.target);
                    }
                });
            }, {
                threshold: 0.15 // 當目標有 15% 進入畫面時就觸發
            });

            // 尋找網頁上所有設定了 .reveal-on-scroll 的區塊並加入觀察
            const items = document.querySelectorAll('.reveal-on-scroll');
            items.forEach(item => observer.observe(item));
        });
    </script>
}
</body>