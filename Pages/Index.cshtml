@page
@model IndexModel
@inject Microsoft.AspNetCore.Mvc.Localization.IHtmlLocalizer<NailArtHub.SharedResource> Localizer
@{
    ViewData["Title"] = "Home page";
}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,400;0,600;1,400&family=Noto+Sans+TC:wght@300;400;500&family=Noto+Serif+TC:wght@500;700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Klee+One:wght@400;600&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<head>
     <style>

            .nailsy-hero {
                background-color: #FAF6F0;
                min-height: 85vh;
                display: flex;
                align-items: center;
                padding: 0 60px 60px 60px;
                font-family: 'Montserrat', sans-serif;
            }

            .hero-text-side {
                flex: 1.4;
                padding-right: 40px;
            }

            .hero-tagline {
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 4px;
                color: #C49A45;
                margin-bottom: 20px;
                font-weight: 600;
            }

            .hero-title {
                font-family: 'Playfair Display', serif;
                font-size: 4.5rem;
                color: #1A1A1A;
                line-height: 1.1;
                margin-bottom: 25px;
                font-weight: 400;
                letter-spacing: -1px;
            }

                .hero-title em {
                    font-style: italic;
                    font-family: 'Playfair Display', serif;
                }

            .hero-description {
                font-size: 1.05rem;
                color: #555555;
                line-height: 1.8;
                margin-bottom: 40px;
                letter-spacing: 0.5px;
                max-width: 90%;
            }

            .btn-satrt {
                display: inline-block;
                border: 1px solid #1A1A1A;
                color: #1A1A1A;
                padding: 15px 45px;
                text-transform: uppercase;
                font-size: 0.9rem;
                letter-spacing: 2px;
                font-weight: 500;
                text-decoration: none;
                transition: all 0.4s ease;
            }

                .btn-satrt:hover {
                    background-color: #1A1A1A;
                    color: #FAF6F0;
                }

            /* Right side pic */
            .hero-image-side {
                flex: 1;
                height: 100vh;
                overflow: hidden;
            }

                .hero-image-side img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                }

            .hero-hand-fade {
                width: 100% !important;
                height: auto !important;
                object-fit: cover !important;
                object-position: top !important;
                margin-bottom: -200px !important;
                position: relative !important;
                z-index: 0 !important;
                -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 75%, rgba(0,0,0,0) 100%) !important;
                mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 75%, rgba(0,0,0,0) 100%) !important;
            }

            .reveal-on-scroll {
                opacity: 0;
                transform: translateY(30px);
                will-change: transform, opacity;
                backface-visibility: hidden;
                transition: opacity 1s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            }

                /* detect scrolling to trigger this class */
                .reveal-on-scroll.active {
                    opacity: 1;
                    transform: translateY(0);
                }

            .feature-card {
                flex: 1;
                background: #FFFDFB;
                padding: 50px 30px;
                border: 1px solid #EAE5DC;
                text-align: center;
                box-shadow: 0 4px 20px rgba(0,0,0,0.02);
            }

            /* Language fonts control  */

            .lang-zh, .lang-en {
                display: none;
            }

            :lang(zh) .lang-zh {
                display: inline;
            }

            :lang(en) a,
            :lang(en) .nav-link,
            :lang(en) .menu-item {
                font-weight: 400 !important;
                letter-spacing: 2px !important;
            }

            :lang(en) .lang-en {
                display: inline !important;
            }

            :lang(en) body {
                font-weight: 300 !important;
            }
            :lang(zh) body,
            :lang(zh) .nailsy-hero,
            :lang(zh) p,
            :lang(zh) div,
            :lang(zh) h1,
            :lang(zh) h2,
            :lang(zh) h3,
            :lang(zh) a {
                font-family: 'Montserrat', 'Noto Sans TC', sans-serif !important;
                font-weight: 300 !important;
                letter-spacing: 1px !important;
            }

            :lang(zh) .hero-title,
            :lang(zh) h2 {
                font-family: "PMingLiU-ExtB", "MingLiU", "Microsoft JhengHei", "Songti TC", "Noto Serif TC", serif !important;
                font-weight: 700 !important;
                color: #1A1A1A !important;
                font-size: 4.0rem !important;
                letter-spacing: 2px !important;
                line-height: 1.35 !important;
            }

            @@font-face {
                font-family: "MySalonFont";
                src: url("/fonts/ChenYuluoyan-2.0-Thin.ttf") format("truetype");
                font-weight: 300;
                font-style: normal;
            }

            :lang(zh) .hero-title em {
                font-family: "MySalonFont", sans-serif !important;
                font-style: normal !important;
                color: #1A1A1A !important;
                font-weight: 300 !important;
                font-size: 5.4rem !important;
                letter-spacing: 6px !important;
                vertical-align: -6px;

                display: inline-block;
                margin-left: 12px;
            }
            /* --- 📱phone version --- */
            @@media screen and (max-width: 768px) {
                .nailsy-hero {
                    flex-direction: column !important;
                    padding: 40px 12px 20px 12px !important;
                    min-height: auto !important;
                }

                .hero-text-side {
                    width: 100% !important;
                    padding-right: 0 !important;
                    text-align: center !important;
                    margin-bottom: 30px;
                }

                :lang(zh) .hero-title, .hero-title {
                    font-size: 2.0rem !important;
                    line-height: 1.2 !important;
                    width: 100% !important;
                    max-width: 100% !important;
                    letter-spacing: 0.5px !important;
                    word-break: keep-all !important;
                    overflow-wrap: break-word !important;
                }

                    :lang(zh) .hero-title em {
                        font-size: 3.2rem !important;
                        margin-left: 0px !important;
                        display: inline-block !important;
                    }

                .hero-description {
                    font-size: 1.1rem !important;
                    line-height: 1.5 !important;
                    margin: 20px auto 30px auto !important;
                }

                .reveal-on-scroll h2,
                .features-section h2 {
                    font-size: 2.2rem !important;
                    text-align: center !important;
                    margin: 30px 0 20px 0 !important;
                }

                .feature-container,
                div:has(> .feature-card) {
                    flex-direction: column !important;
                    gap: 20px !important;
                    padding: 0 10px !important;
                }

                .feature-card {
                    width: 100% !important;
                    max-width: 100% !important;
                    box-sizing: border-box !important;
                    padding: 30px 20px !important;
                    margin-bottom: 15px !important;
                }

                .nailsy-hero p,
                .reveal-on-scroll p,
                .about-section p {
                    font-size: 1.0rem !important;
                    line-height: 1.6 !important;
                    color: #555555 !important;
                    text-align: center !important;
                    margin-bottom: 15px !important;
                }
            }
    </style>
</head>
<body>
<div style="background-color: #FAF6F0; width: 100%; min-height: 100vh; overflow: hidden; margin: 0; padding: 0;">
        <div class="nailsy-hero" style="background-color: transparent; min-height: 85vh; display: flex; align-items: center; padding: 0 60px 60px 60px;">
    <!-- Left side text -->
            <div class="hero-text-side" style="flex: 1; padding-right: 80px;">
                <div class="hero-tagline">@Localizer["Hero_taglineLabel"]</div>
                <h1 class="hero-title">
                    <!-- EN  -->
                    <span class="lang-en">
                        Find the Best<br>
                        <em>Nail Trends</em> Near You.
                    </span>

                    <!-- ZH -->
                    <span class="lang-zh">
                        探索在您身邊的<br>
                        最新<em>美甲潮流</em>
                    </span>
                </h1>
        <div class="hero-description">
                    @Localizer["Hero_Sub_Line1"]<br>
                    @Localizer["Hero_Sub_Line2"]<br>
                    @Localizer["Hero_Sub_Line3"]<br>
                    @Localizer["Hero_Sub_Line4"]
        </div>
    </div>

    <!-- Right side poster -->
            <div class="hero-image-side" style="flex: 1; height: 70vh; position: relative; overflow: visible !important;">
                <img src="~/images/nail-hero.png" class="hero-hand-fade" alt="Minimalist Nail Art">
            </div>
</div>
<!-- ================= Section 2: About ================= -->
        <div class="reveal-on-scroll" style="background-color: transparent; padding: 100px 60px;">
    <div style="max-width: 900px; margin: 0 auto; text-align: center;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 2.8rem; color: #1A1A1A; margin-bottom: 40px; letter-spacing: 1px;">
                    @Localizer["AboutLabel"]
        </h2>
        <p style="font-family: 'Montserrat', sans-serif; font-size: 1.15rem; color: #555555; line-height: 2; letter-spacing: 0.5px;">
                    @Localizer["About_Line1"]<br>
                    @Localizer["About_Line2"]<br>
                    @Localizer["About_Line3"]<br>
                    @Localizer["About_Line4"]<br>
                    @Localizer["About_Line5"]<br>
                    @Localizer["About_Line6"]
        </p>
    </div>
</div>

<!-- ================= Section 3: How to use ================= -->
        <div class="reveal-on-scroll" style="background-color: transparent; padding: 100px 60px;">
    <div style="max-width: 1200px; margin: 0 auto;">

        <!-- Section -->
        <div style="text-align: center; margin-bottom: 80px;">
            <h2 style="font-family: 'Playfair Display', serif; font-size: 2.8rem; color: #1A1A1A; letter-spacing: 1px;">
                        @Localizer["HowItWorksLabel"]
            </h2>
            <p style="font-size: 0.9rem; text-transform: uppercase; letter-spacing: 3px; color: #C49A45; margin-top: 10px; font-weight: 600;">
                        @Localizer["Process_Subtitle"]
            </p>
        </div>

        <div style="display: flex; gap: 40px; justify-content: space-between;">
                    <div class="feature-card">
                        <div style="font-family: 'Playfair Display', serif; font-size: 2rem; color: #C49A45; margin-bottom: 20px;">01</div>
                        <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 15px; color: #1A1A1A;">Big Data Trend Scraping</h3>
                        <p style="color: #666; font-size: 0.95rem; line-height: 1.6;">@Localizer["Step1_Desc"]</p>
                    </div>
                    <div class="feature-card">
                        <div style="font-family: 'Playfair Display', serif; font-size: 2rem; color: #C49A45; margin-bottom: 20px;">02</div>
                        <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 15px; color: #1A1A1A;">Intuitive Tag Filtering</h3>
                        <p style="color: #666; font-size: 0.95rem; line-height: 1.6;">@Localizer["Step2_Desc"]</p>
                    </div>
                    <div class="feature-card">
                        <div style="font-family: 'Playfair Display', serif; font-size: 2rem; color: #C49A45; margin-bottom: 20px;">03</div>
                        <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 15px; color: #1A1A1A;">Curated Salon Matchmaking</h3>
                        <p style="color: #666; font-size: 0.95rem; line-height: 1.6;">@Localizer["Step3_Desc"]</p>
                    </div>
                </div>
        </div><br>
            <!-- Button to Services -->
            <div style="display: flex; justify-content: center; margin-top: 60px;">
                <a asp-page="/Services" class="btn-satrt">@Localizer["ExploreNowLabel"]</a>
            </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
                    // Built an observer
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                        observer.unobserve(entry.target);
                    }
                });
            }, {
                threshold: 0.15
            });

            const items = document.querySelectorAll('.reveal-on-scroll');
            items.forEach(item => observer.observe(item));
        });
    </script>
}
</body>