@page
@model NailArtHub.Pages.PartnerListModel
@{
    ViewData["Title"] = "Our Partner Studios - NailArtHub";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

<style>

    .services-page {
        background-color: #FAF6F0;
        min-height: 100vh;
        font-family: 'Montserrat', sans-serif;
        padding: 60px;
        color: #1A1A1A;
        margin-top: -48px;
    }

    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 3rem;
        text-align: center;
        margin-bottom: 50px;
        letter-spacing: 1px;
    }

    .tag-container {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        justify-content: center;
        max-width: 900px;
        margin: 0 auto 40px auto;
    }

    .tag-pill-btn {
        background-color: #FFFFFF;
        border: 1px solid #EAE5DC;
        padding: 10px 24px;
        border-radius: 30px;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.3s ease;
        letter-spacing: 0.5px;
        font-weight: 500;
        color: #1A1A1A;
        text-decoration: none;
        display: inline-block;
    }

        .tag-pill-btn.active {
            background-color: #1A1A1A;
            color: #FAF6F0;
            border-color: #1A1A1A;
        }

        .tag-pill-btn:hover:not(.active) {
            border-color: #1A1A1A;
        }

    .search-section-wrapper {
        max-width: 600px;
        margin: 0 auto 60px auto;
    }

    .search-style-select {
        width: 100%;
        background-color: #FFFDFB;
        border: 1px solid #EAE5DC;
        padding: 15px 25px;
        font-size: 1rem;
        letter-spacing: 0.5px;
        outline: none;
        transition: border-color 0.3s;
        height: 54px;
        font-family: 'Montserrat', sans-serif;
        color: #1A1A1A;
        cursor: pointer;
        -webkit-appearance: none;
        appearance: none;
        background-image: url("data:image/svg+xml;utf8,<svg fill='%231A1A1A' height='24' viewBox='0 0 24 24' width='24' xmlns='http://www.w3.org/2000/svg'><path d='M7 10l5 5 5-5z'/><path d='M0 0h24v24H0z' fill='none'/></svg>");
        background-repeat: no-repeat;
        background-position: calc(100% - 20px) center;
    }

        .search-style-select:focus {
            border-color: #1A1A1A;
        }

    .results-layout {
        display: flex;
        gap: 50px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .section-subtitle {
        font-family: 'Playfair Display', serif;
        font-size: 1.6rem;
        margin-bottom: 25px;
        border-bottom: 1px solid #EAE5DC;
        padding-bottom: 10px;
    }

    .result-card-shop {
        background: #FFFDFB;
        border: 1px solid #EAE5DC;
        transition: transform 0.3s;
        border-radius: 0;
        overflow: hidden;
    }

        .result-card-shop:hover {
            transform: translateY(-3px);
        }
</style>

<div class="services-page">
    <h1 class="page-title">Partner Studios</h1>

    <div class="tag-container">
        <a asp-page="./PartnerList" asp-route-SelectedTagId="" asp-route-SelectedLocation="@Model.SelectedLocation"
           class="tag-pill-btn @(Model.SelectedTagId == null ? "active" : "")">
            ALL STYLES
        </a>

        @foreach (var tag in Model.AllTags)
        {
            <a asp-page="./PartnerList" asp-route-SelectedTagId="@tag.Id" asp-route-SelectedLocation="@Model.SelectedLocation"
               class="tag-pill-btn @(Model.SelectedTagId == tag.Id ? "active" : "")">
                # @tag.TagName
            </a>
        }
    </div>

    <div class="search-section-wrapper">
        <form method="get" id="locationForm">
            <input type="hidden" name="SelectedTagId" value="@Model.SelectedTagId" />
            <select name="SelectedLocation" asp-for="SelectedLocation" onchange="document.getElementById('locationForm').submit();"
                    class="search-style-select">
                <option value="">Filter by Location (All Taiwan)...</option>
                <optgroup label="Northern Taiwan">
                    <option value="Taipei">Taipei City</option>
                    <option value="New Taipei">New Taipei City</option>
                    <option value="Keelung">Keelung City</option>
                    <option value="Taoyuan">Taoyuan City</option>
                    <option value="HsinchuCounty">Hsinchu County</option>
                    <option value="HsinchuCity">Hsinchu City</option>
                </optgroup>
                <optgroup label="Central Taiwan">
                    <option value="Miaoli">Miaoli County</option>
                    <option value="Taichung">Taichung City</option>
                    <option value="Changhua">Changhua County</option>
                    <option value="Nantou">Nantou County</option>
                    <option value="Yunlin">Yunlin County</option>
                </optgroup>
                <optgroup label="Southern Taiwan">
                    <option value="ChiayiCounty">Chiayi County</option>
                    <option value="ChiayiCity">Chiayi City</option>
                    <option value="Tainan">Tainan City</option>
                    <option value="Kaohsiung">Kaohsiung City</option>
                    <option value="Pingtung">Pingtung County</option>
                </optgroup>
                <optgroup label="Eastern Taiwan">
                    <option value="Yilan">Yilan County</option>
                    <option value="Hualien">Hualien County</option>
                    <option value="Taitung">Taitung County</option>
                </optgroup>
                <optgroup label="Outer Islands">
                    <option value="Penghu">Penghu County</option>
                    <option value="Kinmen">Kinmen County</option>
                    <option value="Matsu">Matsu (Lienchiang County)</option>
                </optgroup>
                @foreach (var loc in Model.LocationList)
                {
                    <option value="@loc">📍 @loc</option>
                }
            </select>
        </form>
    </div>

    <div class="results-layout">
        <div style="flex: 1;">
            <h2 class="section-subtitle">Selected Studios</h2>

            @if (Model.DisplayShops == null || !Model.DisplayShops.Any())
            {
                <div style="text-align: center; padding: 40px; color: #888; background: #FFFDFB; border: 1px solid #EAE5DC;">
                    <p>No studios found matching the current filters.</p>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    @foreach (var shop in Model.DisplayShops)
                    {
                        <div class="col">
                            <div class="card h-100 result-card-shop">
                                <div style="width: 100%; height: 240px; overflow: hidden; position: relative; border-bottom: 1px solid #EAE5DC; background-color: #FFFDFB;">
                                    @if (!string.IsNullOrEmpty(shop.PinterestUrl))
                                    {
                                        var cleanedUrl = shop.PinterestUrl.Trim();
                                        if (cleanedUrl.Contains("?")) { cleanedUrl = cleanedUrl.Split('?')[0]; }
                                        if (!cleanedUrl.EndsWith("/")) { cleanedUrl += "/"; }

                                        <div style="margin-top: -65px; width: 100%; height: 320px; overflow: hidden;">
                                            <blockquote class="instagram-media" data-instgrm-permalink="@cleanedUrl" data-instgrm-version="14" style="background: transparent; border:0; margin:0; padding:0; width:100%;"></blockquote>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center justify-content-center h-100" style="background-color: #FAF6F0;">
                                            <span style="font-size: 0.8rem; color: #bbb; letter-spacing: 1px;">NAH SELECTED</span>
                                        </div>
                                    }
                                    <span class="position-absolute top-0 start-0 m-3" style="background-color: #FFFDFB; color: #1A1A1A; font-size: 11px; font-weight: 500; border: 1px solid #EAE5DC; padding: 4px 8px; z-index: 9;">
                                        📍 @shop.Location
                                    </span>
                                </div>

                                <div class="card-body p-4">
                                    <h3 style="font-family: 'Playfair Display', serif; margin: 0 0 10px 0; font-size: 1.3rem; color: #1A1A1A;">
                                        @shop.ShopName
                                    </h3>
                                    <p style="color: #666; font-size: 0.85rem; line-height: 1.5; min-height: 38px; margin-bottom: 15px;">
                                        @shop.Address
                                    </p>
                                    <div class="d-flex flex-wrap gap-1" style="min-height: 24px;">
                                        @if (shop.ShopTagBridges != null && shop.ShopTagBridges.Any())
                                        {
                                            foreach (var bridge in shop.ShopTagBridges)
                                            {
                                                <span style="color: #C49A45; font-weight: 600; font-size: 0.8rem; margin-right: 6px;">
                                                    #@bridge.NailTag?.TagName
                                                </span>
                                            }
                                        }
                                    </div>
                                </div>

                                <div class="card-footer p-4 bg-transparent" style="border-top: 1px solid #EAE5DC;">
                                    @if (!string.IsNullOrEmpty(shop.InstagramUrl))
                                    {
                                        <a href="@shop.InstagramUrl" target="_blank" style="font-size: 0.85rem; color: #1A1A1A; text-decoration: underline; font-weight: 500;">
                                            View Instagram →
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script async src="//www.instagram.com/embed.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () { if (window.instgrm) { window.instgrm.Embeds.process(); } });
    </script>
}