@page
@model NailArtHub.Pages.PartnerListModel
@inject Microsoft.AspNetCore.Mvc.Localization.IHtmlLocalizer<NailArtHub.SharedResource> Localizer
@{
    ViewData["Title"] = "Our Partner Studios - NailArtHub";

    ViewData["SelectedCity"] = Model.SelectedCity;
    ViewData["SelectedDistrict"] = Model.SelectedDistrict;
    var queryParams = new Dictionary<string, string>();
    if (ViewContext.HttpContext.Request.Query.ContainsKey("culture"))
    {
        queryParams["culture"] = ViewContext.HttpContext.Request.Query["culture"].ToString();
    }
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<head>
<style>
    .services-page {
        background-color: #FAF6F0;
        min-height: 100vh;
        font-family: 'Montserrat', sans-serif;
        padding: 60px;
        color: #1A1A1A;
    }

    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 3rem;
        text-align: center;
        margin-bottom: 50px;
        letter-spacing: 1px;
    }

    :lang(zh) .page-title {
        font-family: "PMingLiU-ExtB", "MingLiU", "Microsoft JhengHei", "Songti TC", "Noto Serif TC", serif !important;
        font-weight: 700 !important;
        font-size: 3.2rem !important;
        letter-spacing: 2px !important;
        color: #1A1A1A !important;
    }

    .tag-container {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        justify-content: center;
        margin: 0 auto 40px auto;
    }

    .tag-pill-btn {
        background-color: #FFFDFB;
        border: 1px solid #EAE5DC;
        padding: 8px 15px;
        border-radius: 30px;
        white-space: nowrap;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.3s ease;
        letter-spacing: 0.5px;
        font-weight: 500;
        user-select: none;
        display: inline-block;
        line-height: 1.2;
    }

    :lang(zh) .tag-pill-btn {
        font-family: 'Montserrat', 'Noto Sans TC', sans-serif !important;
        font-weight: 300 !important;
        letter-spacing: 1px !important;
    }

    .tag-pill-btn.active {
        background-color: #1A1A1A;
        color: #FAF6F0;
        border-color: #1A1A1A;
    }

    :lang(zh) .tag-pill-btn.active {
        font-weight: 400 !important;
    }

    .section-subtitle {
        font-family: 'Playfair Display', serif;
        font-size: 1.6rem;
        margin-bottom: 25px;
        border-bottom: 1px solid #EAE5DC;
        padding-bottom: 10px;
    }

    :lang(zh) .section-subtitle {
        font-family: "PMingLiU-ExtB", "MingLiU", "Microsoft JhengHei", "Songti TC", "Noto Serif TC", serif !important;
        font-weight: 700 !important;
        font-size: 1.6rem !important;
        letter-spacing: 1.5px !important;
    }

    .results-layout {
        display: flex;
        gap: 50px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .result-card-shop {
        background: #FFFDFB;
        border: 1px solid #EAE5DC;
        transition: transform 0.3s;
        border-radius: 0;
        overflow: hidden;
    }

    .result-card-shop:hover {
        transform: translateY(-3px);
    }

    .join-us-btn {
        display: block;
        width: 100%;
        background-color: #FFFDFB;
        border: 1px solid #1A1A1A;
        color: #1A1A1A;
        padding: 12px;
        text-align: center;
        font-size: 0.9rem;
        font-weight: 500;
        letter-spacing: 1px;
        text-decoration: none;
        margin-bottom: 20px;
        transition: all 0.3s;
    }

    :lang(zh) .join-us-btn {
        font-family: 'Montserrat', 'Noto Sans TC', sans-serif !important;
        font-weight: 300 !important;
        letter-spacing: 2px !important;
    }

    .join-us-btn:hover {
        background-color: #1A1A1A;
        color: #FAF6F0;
    }
</style>
</head>
<body>
<div class="services-page">
    <h1 class="page-title">@Localizer["Partner_Studios"]</h1>

    <form method="get" id="locationForm">
        <input type="hidden" id="hiddenTagId" name="SelectedTagId" value="@Model.SelectedTagId" />

        <div class="tag-container">
            @{
                bool isAllSelected = Model.SelectedTagId == null;
            }
            <label class="tag-pill-btn @(isAllSelected ? "active" : "")"
                    onclick="submitWithTag('')">
                @Localizer["All_StylesLabel"]
            </label>

            @foreach (var tag in Model.AllTags)
            {
                bool isSelected = Model.SelectedTagId == tag.Id;

                <label class="tag-pill-btn @(isSelected ? "active" : "")"
                       onclick="submitWithTag('@tag.Id')">
                    # @tag.TagName
                </label>
            }
        </div>

        <!-- ZH/EN -->
        <div class="search-bar-wrapper" style="max-width: 600px; margin-left: auto; margin-right: auto; margin-bottom: 35px;">
            @await Html.PartialAsync("_LocationSelector")
        </div>
    </form>

    <div class="results-layout">
        <div style="flex: 1;">
            <h2 class="section-subtitle">@Localizer["Selected_Studios"]</h2>

            @if (Model.DisplayShops == null || !Model.DisplayShops.Any())
            {
                <div style="text-align: center; padding: 40px; color: #888; background: #FFFDFB; border: 1px solid #EAE5DC;">
                    <p>@Localizer["No_studios_found"]</p>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    @foreach (var shop in Model.DisplayShops)
                    {
                        <div class="col">
                            <div class="card h-100 result-card-shop">
                                <div style="width: 100%; height: 260px; overflow: hidden; position: relative; border-bottom: 1px solid #EAE5DC; background-color: #FFFDFB;">
                                    @if (!string.IsNullOrEmpty(shop.PinterestUrl))
                                    {
                                        var cleanedUrl = shop.PinterestUrl.Trim();
                                        if (cleanedUrl.Contains("?")) { cleanedUrl = cleanedUrl.Split('?')[0]; }
                                        if (!cleanedUrl.EndsWith("/")) { cleanedUrl += "/"; }

                                        <div style="margin-top: -130px; width: 100%; height: 390px; overflow: hidden;">
                                            <blockquote class="instagram-media" data-instgrm-permalink="@cleanedUrl" data-instgrm-version="14" style="background: transparent; border:0; margin:0; padding:0; width:100%;"></blockquote>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center justify-content-center h-100" style="background-color: #FAF6F0;">
                                            <span style="font-size: 0.8rem; color: #bbb; letter-spacing: 1px;">NAH SELECTED</span>
                                        </div>
                                    }
                                        <span class="position-absolute top-0 start-0 m-3" style="background-color: #FFFDFB; color: #1A1A1A; font-size: 11px; font-weight: 500; border: 1px solid #EAE5DC; padding: 4px 8px; z-index: 9;">
                                            @if (!string.IsNullOrEmpty(shop.City))
                                            {
                                                <span>📍 @shop.City @shop.District</span>
                                            }
                                            else if (!string.IsNullOrEmpty(shop.Location) && shop.Location != "Pending")
                                            {
                                                <span>📍 @shop.Location</span>
                                            }
                                            else
                                            {
                                                <span>📍 未定</span>
                                            }
                                        </span>
                                </div>

                                <div class="card-body p-4">
                                    <h3 style="font-family: 'Playfair Display', serif; margin: 0 0 10px 0; font-size: 1.3rem; color: #1A1A1A;">
                                        @shop.ShopName
                                    </h3>
                                    <p style="color: #666; font-size: 0.85rem; line-height: 1.5; min-height: 38px; margin-bottom: 15px;">
                                        @shop.Address
                                    </p>
                                    <div class="d-flex flex-wrap gap-1" style="min-height: 24px;">
                                        @if (shop.ShopTagBridges != null && shop.ShopTagBridges.Any())
                                        {
                                            foreach (var bridge in shop.ShopTagBridges)
                                            {
                                                <span style="color: #C49A45; font-weight: 600; font-size: 0.8rem; margin-right: 6px;">
                                                    #@bridge.NailTag?.TagName
                                                </span>
                                            }
                                        }
                                    </div>
                                </div>

                                <div class="card-footer p-4 bg-transparent" style="border-top: 1px solid #EAE5DC;">
                                    @if (!string.IsNullOrEmpty(shop.InstagramUrl))
                                    {
                                        <a href="@shop.InstagramUrl" target="_blank" style="font-size: 0.85rem; color: #1A1A1A; text-decoration: underline; font-weight: 500;">
                                            @Localizer["GoInstagram"] →
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <br>
                <div class="w-50 mx-auto">
                    <a asp-page="/PartnerForm" asp-all-route-data="queryParams" class="join-us-btn" style="margin-bottom: 0;">
                        @Localizer["Join_us"]
                    </a>
                </div>
                <br>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script async src="//www.instagram.com/embed.js"></script>
    <script>
        function submitWithTag(tagId) {
        const form = document.getElementById("locationForm");
        const hiddenInput = document.getElementById("hiddenTagId");

        if (hiddenInput) {
        hiddenInput.value = tagId;
        }
        if (form) {
        form.submit();
        }
        }
    </script>
}
</body>