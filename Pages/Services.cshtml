@page
@model ServicesModel
@inject Microsoft.AspNetCore.Mvc.Localization.IHtmlLocalizer<NailArtHub.SharedResource> Localizer
@{
    ViewData["Title"] = "Explore Services";

    var queryParams = new Dictionary<string, string>();
    if (ViewContext.HttpContext.Request.Query.ContainsKey("culture"))
    {
        queryParams["culture"] = ViewContext.HttpContext.Request.Query["culture"].ToString();
    }
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<head>
<style>
    .services-page {
        background-color: #FAF6F0;
        min-height: 100vh;
        font-family: 'Montserrat', sans-serif;
        padding: 60px;
        color: #1A1A1A;
    }

    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 3rem;
        text-align: center;
        margin-bottom: 50px;
        letter-spacing: 1px;
    }

    :lang(zh) .page-title {
        font-family: "PMingLiU-ExtB", "MingLiU", "Microsoft JhengHei", "Songti TC", "Noto Serif TC", serif !important;
        font-weight: 700 !important;
        font-size: 3.2rem !important;
        letter-spacing: 2px !important;
    }

    .tag-container {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        justify-content: center;
        margin: 0 auto 40px auto;
    }

    .tag-pill {
        background-color: #FFFDFB;
        border: 1px solid #EAE5DC;
        padding: 8px 15px;
        border-radius: 30px;
        white-space: nowrap;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.3s ease;
        letter-spacing: 0.5px;
        font-weight: 500;
        user-select: none;
        display: inline-block;
        line-height: 1.2;
    }

    :lang(zh) .tag-pill {
        font-family: 'Montserrat', 'Noto Sans TC', sans-serif !important;
        font-weight: 300 !important;
        letter-spacing: 1px !important;
    }

    .tag-pill.active {
        background-color: #1A1A1A;
        color: #FAF6F0;
        border-color: #1A1A1A;
    }

    :lang(zh) .tag-pill.active {
        font-weight: 400 !important;
    }

    .results-layout {
        display: flex;
        gap: 50px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .left-results-side {
        flex: 1.5;
    }

    .right-salon-side {
        flex: 1;
    }

    .section-subtitle {
        font-family: 'Playfair Display', serif;
        font-size: 1.6rem;
        margin-bottom: 25px;
        border-bottom: 1px solid #EAE5DC;
        padding-bottom: 10px;
    }

    :lang(zh) .section-subtitle {
        font-family: "PMingLiU-ExtB", "MingLiU", "Microsoft JhengHei", "Songti TC", "Noto Serif TC", serif !important;
        font-weight: 700 !important;
        font-size: 1.6rem !important;
        letter-spacing: 1.5px !important;
    }

    .result-card {
        background: #FFFDFB;
        border: 1px solid #EAE5DC;
        padding: 30px;
        margin-bottom: 20px;
        transition: transform 0.3s;
    }

        .result-card:hover {
            transform: translateY(-3px);
        }

    .join-us-btn {
        display: block;
        width: 100%;
        background-color: #FFFDFB;
        border: 1px solid #1A1A1A;
        color: #1A1A1A;
        padding: 12px;
        text-align: center;
        font-size: 0.9rem;
        font-weight: 500;
        letter-spacing: 1px;
        text-decoration: none;
        margin-bottom: 20px;
        transition: all 0.3s;
    }

    :lang(zh) .join-us-btn {
        font-family: 'Montserrat', 'Noto Sans TC', sans-serif !important;
        font-weight: 300 !important;
        letter-spacing: 2px !important;
    }

    .join-us-btn:hover {
        background-color: #1A1A1A;
        color: #FAF6F0;
    }

    .salon-card {
        background: #FFFDFB;
        border: 1px solid #C49A45;
        padding: 25px;
        margin-bottom: 20px;
        border-radius: 4px;
    }
</style>
</head>
<body>
    @if (TempData["IsCrawling"] as bool? == true)
    {
        <div id="loading-overlay" style="position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(255,255,255,0.9); z-index:9999; display:flex; flex-direction:column; justify-content:center; align-items:center;">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
            <h3 style="margin-top: 20px; font-family: 'Playfair Display';">@Localizer["SearchingLabel"]@TempData["TargetTag"]@Localizer["TrendyLabel"]</h3>
            <p>@Localizer["WaitingLabel"]</p>
        </div>
    }
<div class="services-page">
    <h1 class="page-title">@Localizer["Explore_Trends_Services"]</h1>

    <form method="get" id="filterForm">
        <input type="hidden" id="hiddenTagId" name="SelectedTagId" value="@Model.SelectedTagId" />
        <div class="tag-container">
            <div class="tag-pill @(!Model.SelectedTagId.HasValue ? "active" : "")" onclick="submitWithTag('')" >
                @Localizer["All_StylesLabel"]
            </div>

            @foreach (var tag in Model.AllTags.Take(7))
            {
                bool isSelected = Model.SelectedTagId.HasValue && Model.SelectedTagId.Value == tag.Id;
                <div class="tag-pill @(isSelected ? "active" : "")" onclick="submitWithTag('@tag.Id')" >
                    # @tag.TagName
                </div>
            }
        </div>

        <div class="search-bar-container" style="display: flex; gap: 10px; max-width: 1200px; margin: 0 auto 40px auto;" >
            <input type="text" name="SearchQuery"
                   value="@Model.SearchQuery"
                   placeholder="Search for styles, colors, or keywords..."
                   style="flex: 1; border: 1px solid #1A1A1A; padding: 15px 20px; font-family: 'Montserrat', sans-serif;" />

            <button type="button" onclick="submitSearch()"
                    style="background-color: #1A1A1A; color: #FFFDFB; border: none; padding: 0 40px; font-weight: 600; cursor: pointer; text-transform: uppercase; letter-spacing: 1px;">
                SEARCH
            </button>
        </div>

        <div class="results-layout">
            <div class="left-results-side">
                <h2 class="section-subtitle">@Localizer["Trending_Inspirations"]</h2>

                @if (!Model.TrendResults.Any())
                {
                    <div style="text-align: center; padding: 40px; color: #888;">
                        <p>@Localizer["No_trending_styles"]</p>
                    </div>
                }
                else
                {
                    @foreach (var trend in Model.TrendResults)
                    {
                        <div class="result-card" style="display: flex; gap: 20px; align-items: center;">
                            <div style="flex: 0.6; min-width: 120px; max-width: 150px; height: 180px; overflow: hidden; border-radius: 8px;">
                                <img src="@trend.ImageUrl" alt="@trend.Title" style="width: 100%; height: 100%; object-fit: cover;">
                            </div>
                            <div style="flex: 1.4;">
                                <span style="color: #C49A45; font-weight: 600; letter-spacing: 1px;">
                                    # @Localizer[trend.Tag]
                                </span>
                                <h3 style="font-family: 'Playfair Display', serif; margin: 8px 0 12px 0; font-size: 1.3rem;">
                                    @trend.Title
                                </h3>
                                <p style="color: #888; font-size: 0.8rem; margin-bottom: 15px;">
                                    📅 Discovery Date: @trend.CrawledAt
                                </p>
                                <a href="@trend.SourceUrl" target="_blank" style="font-size: 0.85rem; color: #1A1A1A; text-decoration: underline;">
                                    @Localizer["GoPinterest"] →
                                </a>
                            </div>
                        </div>
                    }
                }
            </div>

            <div class="right-salon-side">
                <h2 class="section-subtitle">@Localizer["Featured_Salons"]</h2>
                <a asp-page="/PartnerForm" asp-all-route-data="queryParams" class="join-us-btn">@Localizer["Join_us"]</a>
                <div style="background-color: #FFFDFB; border: 1px solid #EAE5DC; padding: 15px; margin-bottom: 20px; border-radius: 4px;">
                    <p style="font-size: 0.85rem; font-weight: 600; margin-bottom: 10px; color: #1A1A1A;">@Localizer["Find_ around_you"]：</p>
                    @await Html.PartialAsync("_LocationSelector")
                </div>

                @if (Model.FeaturedShops != null && Model.FeaturedShops.Any())
                {
                        @using System.Text.RegularExpressions
                    @foreach (var shop in Model.FeaturedShops)
                    {
                        <div class="salon-card">
                            <h4 style="font-weight: 600; margin-bottom: 5px;">@shop.ShopName</h4>
                                @{
                                    string cleanAddress = shop.Address ?? "";
                                    cleanAddress = Regex.Replace(cleanAddress, @"^[a-zA-Z\s']+", "").Trim();
                                }
                            <p style="font-size: 0.9rem; color: #666; margin-bottom: 10px;">📍 @shop.Address</p>
                            @if (shop.ShopTagBridges != null && shop.ShopTagBridges.Any())
                            {
                                @foreach (var bridge in shop.ShopTagBridges)
                                {
                                    <span style="background: #EAE5DC; padding: 3px 8px; font-size: 0.75rem; margin-right: 5px;">
                                        #@bridge.NailTag?.TagName
                                    </span>
                                }
                            }
                        </div>
                    }
                }
                else
                {
                    <p style="font-size: 0.9rem; color: #999; font-style: italic;">@Localizer["No_studios_found"]</p>
                }
            </div>
        </div>
    </form>
</div>

<script>
    function getCultureParam() {
        const urlParams = new URLSearchParams(window.location.search);
        return urlParams.get('culture') || "";
    }
    function submitSearch() {
        const overlay = document.getElementById("loading-overlay");
        if (overlay) {
            overlay.style.display = "flex";
        }
        const form = document.getElementById("filterForm");
        const hiddenInput = document.getElementById("hiddenTagId");
        if (hiddenInput) hiddenInput.value = "";
        appendCultureToForm(form);
        form.submit();
    }

    function submitWithTag(tagId) {
        const overlay = document.getElementById("loading-overlay");
        if (overlay && tagId !== "") {
            overlay.style.display = "flex";
       }
        const form = document.getElementById("filterForm");
        const hiddenInput = document.getElementById("hiddenTagId");
        const searchInput = document.querySelector('input[name="SearchQuery"]');

        if (searchInput) {
            searchInput.value = "";
        }

        if (hiddenInput) {
            hiddenInput.value = tagId;
        }
        appendCultureToForm(form);
        form.submit();
    }
    function appendCultureToForm(form) {
        const culture = getCultureParam();
        if (culture) {
            let input = form.querySelector('input[name="culture"]');
            if (!input) {
                input = document.createElement("input");
                input.type = "hidden";
                input.name = "culture";
                form.appendChild(input);
            }
            input.value = culture;
        }
    }
            document.addEventListener("DOMContentLoaded", function() {
                const citySelect = document.getElementById("SelectedCity") || document.querySelector("select[name='SelectedCity']");
                const distSelect = document.getElementById("SelectedDistrict") || document.querySelector("select[name='SelectedDistrict']");
                const form = document.getElementById("filterForm");

                if (citySelect) {
                    citySelect.addEventListener("change", function() {
                        appendCultureToForm(form);
                        form.submit();
                    });
                }
                if (distSelect) {
                    distSelect.addEventListener("change", function() {
                        appendCultureToForm(form);
                        form.submit();
                    });
                }
            });

</script>
</body>